{
    "manifest_version": 3,
    "name": "Time = Asset Dashboard",
    "version": "1.0",
    "description": "Tracks your time on SNS and visualizes the lost asset value.",
    "permissions": [
        "tabs",
        "storage",
        "alarms",
        "history"
    ],
    "host_permissions": [
        "*://*.youtube.com/*",
        "*://*.x.com/*",
        "*://*.twitter.com/*",
        "*://*.instagram.com/*",
        "*://*.tiktok.com/*",
        "<all_urls>"
    ],
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["content.js"],
            "run_at": "document_idle"
        }
    ],
    "background": {
        "service_worker": "background.js"
    },
    "web_accessible_resources": [
        {
            "resources": [
                "blocked.html",
                "blocked.js"
            ],
            "matches": [
                "<all_urls>"
            ]
        }
    ],
    "action": {
        "default_popup": "popup.html"
    }
}