# Copy this file to .dev.vars when running Cloudflare local dev.
# Required by Next.js routes running on Workers.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_API_BASE=https://your-api.example.com/api

# Only needed by server-side API routes in apps/web/app/api/auth/*
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
